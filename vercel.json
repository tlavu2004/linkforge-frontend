{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://your-backend-domain.com/api/:path*"
        },
        {
            "source": "/r/:path*",
            "destination": "https://your-backend-domain.com/r/:path*"
        },
        {
            "source": "/((?!api|r).*)",
            "destination": "/index.html"
        }
    ]
}