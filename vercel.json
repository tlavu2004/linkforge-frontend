{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://linkforge-backend-r0tk.onrender.com/api/:path*"
        },
        {
            "source": "/r/:path*",
            "destination": "https://linkforge-backend-r0tk.onrender.com/r/:path*"
        },
        {
            "source": "/((?!api|r).*)",
            "destination": "/index.html"
        }
    ]
}